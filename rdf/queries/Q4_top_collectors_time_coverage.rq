PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX prov:    <http://www.w3.org/ns/prov#>
PREFIX locrel:  <http://id.loc.gov/vocabulary/relators/>
PREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:     <http://www.w3.org/2001/XMLSchema#>

SELECT
  ?collector
  (SAMPLE(?collectorLabelFinal) AS ?collectorLabel)
  ?year
  (COUNT(DISTINCT ?tale) AS ?taleCount)
WHERE {
  ?tale dcterms:isPartOf ?volume .
  FILTER(CONTAINS(STR(?volume), "/rdf/volume/")) .

  ?volume prov:qualifiedAttribution ?att .
  ?att a prov:Attribution ;
       prov:agent ?collector ;
       prov:hadRole locrel:col .

  ?tale dcterms:created ?taleDate .
  FILTER(datatype(?taleDate) = xsd:date) .
  BIND(YEAR(?taleDate) AS ?year) .

  OPTIONAL { ?collector rdfs:label ?lblEn . FILTER(LANG(?lblEn) = "en") }

  OPTIONAL { ?collector rdfs:label ?lblAny . }
  BIND(STR(?lblAny) AS ?lblStr) .
  BIND(
    IF(
      REGEX(?lblStr, "'label_en'\\s*:\\s*'[^']+'"),
      REPLACE(?lblStr, ".*'label_en'\\s*:\\s*'([^']+)'.*", "$1"),
      ""
    ) AS ?labelEnExtracted
  )

  BIND(
    COALESCE(STR(?lblEn), ?labelEnExtracted) AS ?collectorLabelFinal
  )

  FILTER(STRLEN(?collectorLabelFinal) > 0)
}
GROUP BY ?collector ?year
ORDER BY ?year DESC(?taleCount)