<?xml version="1.0"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns="https://eugeniavd.github.io/magic_tagger/rdf/ontology#"
    xml:base="https://eugeniavd.github.io/magic_tagger/rdf/ontology"
    xmlns:rft="https://eugeniavd.github.io/magic_tagger/rdf/ontology#"
    xmlns:dc="http://purl.org/dc/elements/1.1/"
    xmlns:dcterms="http://purl.org/dc/terms/"
    xmlns:dcmitype="http://purl.org/dc/dcmitype/"
    xmlns:crm="http://www.cidoc-crm.org/cidoc-crm/"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:foaf="http://xmlns.com/foaf/0.1/"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:skos="http://www.w3.org/2004/02/skos/core#"
    xmlns:locrel="http://id.loc.gov/vocabulary/relators/"
    xmlns:prov="http://www.w3.org/ns/prov#">

    <owl:Ontology rdf:about="https://eugeniavd.github.io/magic_tagger/rdf/ontology#">
        <dc:created>01/02/2026</dc:created>
        <dc:creator xml:lang="en">Evgeniia Vdovichenko</dc:creator>
        <dc:description xml:lang="en">Minimal, reuse-first knowledge model representing a defined corpus of Russian-language tales of magic 
            from the Estonian Folklore Archives as a FAIR-oriented knowledge graph for faceted retrieval and type-assignment decision support</dc:description>
        <rdfs:label xml:lang="en">Russian Folktale Knowledge Graph</rdfs:label>
        <owl:versionInfo rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1.0</owl:versionInfo>
        
    </owl:Ontology>


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- http://purl.org/dc/elements/1.1/created -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/created"/>
    


    <!-- http://purl.org/dc/elements/1.1/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#about -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#about"/>

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <!-- https://eugeniavd.github.io/magic_tagger/rdf/ontology#ageAtRecording -->

    <owl:DatatypeProperty rdf:about="https://eugeniavd.github.io/magic_tagger/rdf/ontology#ageAtRecording">
    <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:comment xml:lang="en">
        Age of the person as recorded in the archival source at the time of recording.
        This property is used when the source gives age instead of a birth date.
    </rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#ageAtRecording"/>
    <rdfs:label xml:lang="en">age at recording</rdfs:label>
    </owl:DatatypeProperty>


    <!-- ========= DCTERMS properties used ========= -->

    <!-- http://purl.org/dc/terms/accessRights -->

    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/accessRights">
    <rdfs:domain rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleRecording"/>
    <rdfs:range rdf:resource="http://purl.org/dc/terms/RightsStatement"/>
    <rdfs:comment xml:lang="en">
        Information about who can access the resource or an indication of its security status.
    </rdfs:comment>
    <rdfs:isDefinedBy>http://purl.org/dc/terms/accessRights</rdfs:isDefinedBy>
    <rdfs:label xml:lang="en">Access Rights</rdfs:label>
    </owl:ObjectProperty>
    

    <!-- http://purl.org/dc/terms/isPartOf -->

    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/isPartOf">
    <rdfs:comment xml:lang="en">
        A related resource in which the described resource is physically or logically included.
        In this profile it is used for archival containment, e.g. TaleRecording in Volume and
        Volume in Collection.
    </rdfs:comment>
    <rdfs:isDefinedBy>http://purl.org/dc/terms/isPartOf</rdfs:isDefinedBy>
    <rdfs:label xml:lang="en">Is Part Of</rdfs:label>
    </owl:ObjectProperty>

    
    <!-- http://purl.org/dc/terms/subject -->
    
    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/subject">
    <rdfs:domain rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleContent"/>
    <rdfs:range rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleType"/>
    <rdfs:comment xml:lang="en">
        A topic or classification assigned to the abstract tale content.
        In this profile it is used to connect TaleContent to controlled folktale type concepts,
        including ATU concepts represented as skos:Concept.
    </rdfs:comment>
    <rdfs:isDefinedBy>http://purl.org/dc/terms/subject</rdfs:isDefinedBy>
    <rdfs:label xml:lang="en">Subject</rdfs:label>
    </owl:ObjectProperty>

    <!-- http://purl.org/dc/terms/source -->

    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/source">
    <rdfs:domain rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleType"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Resource"/>
    <rdfs:comment xml:lang="en">
        A related resource from which the described tale type is derived or documented.
        In this profile it is used to link a TaleType concept to the bibliographic source
        that defines, documents, or standardizes that type.
    </rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/source"/>
    <rdfs:label xml:lang="en">source</rdfs:label>
    </owl:ObjectProperty>



    <!-- ========= PROV-O properties used ========= -->
    
    <!-- http://www.w3.org/ns/prov#qualifiedAttribution -->
    
    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#qualifiedAttribution">
    <rdfs:domain rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleRecording"/>
    <rdfs:range rdf:resource="http://www.w3.org/ns/prov#Attribution"/>
    <rdfs:comment xml:lang="en">
        Attribution is the ascribing of an entity to an agent. In this profile it is used on
        TaleRecording to represent agents associated with a particular recorded tale entry,
        including narrators, collectors, and other participants, expressed through qualified attribution.
    </rdfs:comment>
    <rdfs:isDefinedBy>http://www.w3.org/ns/prov#qualifiedAttribution</rdfs:isDefinedBy>
    <rdfs:label xml:lang="en">qualifiedAttribution</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasAttributedTo">
    <rdfs:domain rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleRecording"/>
    <rdfs:range rdf:resource="http://www.w3.org/ns/prov#Agent"/>
    <rdfs:comment xml:lang="en">
        Links a TaleRecording to an agent to whom the recorded tale entry is attributed.
        In this profile it may be used for narrators, collectors, and other agents associated
        with the recording.
    </rdfs:comment>
    <rdfs:isDefinedBy>http://www.w3.org/ns/prov#wasAttributedTo</rdfs:isDefinedBy>
    <rdfs:label xml:lang="en">wasAttributedTo</rdfs:label>
    </owl:ObjectProperty>


    <!-- http://www.w3.org/ns/prov#agent -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#agent">
    <rdfs:domain rdf:resource="http://www.w3.org/ns/prov#Attribution"/>
    <rdfs:range rdf:resource="http://www.w3.org/ns/prov#Agent"/>
    <rdfs:comment xml:lang="en">
        Links a qualified attribution to the agent to whom the TaleRecording is attributed.
    </rdfs:comment>
    <rdfs:isDefinedBy>http://www.w3.org/ns/prov#agent</rdfs:isDefinedBy>
    <rdfs:label xml:lang="en">agent</rdfs:label>
    </owl:ObjectProperty>


    <!-- http://www.w3.org/ns/prov#hadRole -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#hadRole">
    <rdfs:domain rdf:resource="http://www.w3.org/ns/prov#Attribution"/>
    <rdfs:range rdf:resource="http://www.w3.org/ns/prov#Role"/>
    <rdfs:comment xml:lang="en">
        The role that an agent had with respect to a TaleRecording, expressed in a qualified attribution.
        In this profile, role values include locrel:col for collector and locrel:nrt for narrator.
    </rdfs:comment>
    <rdfs:isDefinedBy>http://www.w3.org/ns/prov#hadRole</rdfs:isDefinedBy>
    <rdfs:label xml:lang="en">hadRole</rdfs:label>
    </owl:ObjectProperty>

<!-- http://www.w3.org/ns/prov#wasDerivedFrom -->

<owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasDerivedFrom">
    <rdfs:domain rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleRecording"/>
    <rdfs:range rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleContent"/>
    <rdfs:comment xml:lang="en">
        Links an archival tale recording to the abstract tale content from which the recorded text
        is derived or which it documents as a particular recorded instantiation.
    </rdfs:comment>
    <rdfs:isDefinedBy>http://www.w3.org/ns/prov#wasDerivedFrom</rdfs:isDefinedBy>
    <rdfs:label xml:lang="en">wasDerivedFrom</rdfs:label>
</owl:ObjectProperty>


    <!-- ========= FOAF properties used ========= -->
    
    <!-- http://xmlns.com/foaf/0.1/page -->

    <owl:ObjectProperty rdf:about="http://xmlns.com/foaf/0.1/page">
    <rdfs:comment xml:lang="en">
        A page or document about a thing.
    </rdfs:comment>
    <rdfs:isDefinedBy>http://xmlns.com/foaf/0.1/page</rdfs:isDefinedBy>
    <rdfs:label xml:lang="en">page</rdfs:label>
    </owl:ObjectProperty>



      <!-- ========= CIDOC-CRM properties used ========= -->

    <!-- http://www.cidoc-crm.org/cidoc-crm/P128_carries -->

    <owl:ObjectProperty rdf:about="http://www.cidoc-crm.org/cidoc-crm/P128_carries">
    <rdfs:domain rdf:resource="http://purl.org/dc/terms/BibliographicResource"/>
    <rdfs:range rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleRecording"/>
    <rdfs:comment xml:lang="en">
        Relates a physical carrier to the recorded linguistic object it carries.
        In this profile the carrier bears a TaleRecording, not the abstract tale content.
    </rdfs:comment>
    <rdfs:isDefinedBy>http://www.cidoc-crm.org/cidoc-crm/P128_carries</rdfs:isDefinedBy>
    <rdfs:label xml:lang="en">carries</rdfs:label>
    </owl:ObjectProperty>

    <!-- ========= SKOS properties used ========= -->

    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme">
    <rdfs:domain rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleType"/>
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    <rdfs:comment xml:lang="en">
        Relates a concept to a concept scheme. In this profile it is used to link a folktale type
        concept to its classification scheme, such as the ATU scheme.
    </rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
    <rdfs:label xml:lang="en">in scheme</rdfs:label>
    </owl:ObjectProperty>


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->
    
     <!-- http://www.w3.org/2000/01/rdf-schema#label -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#label">
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
    <rdfs:comment xml:lang="en">
        A human-readable version of a resource's name.
    </rdfs:comment>
    <rdfs:isDefinedBy>http://www.w3.org/2000/01/rdf-schema#label</rdfs:isDefinedBy>
    <rdfs:label xml:lang="en">label</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/birthDate">
    <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
    <rdfs:comment xml:lang="en">
        Date of birth of a person. In this profile it may also be recorded as a year-only value where only the birth year is known.
    </rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://schema.org/birthDate"/>
    <rdfs:label xml:lang="en">birthDate</rdfs:label>
    </owl:DatatypeProperty>
    
    <!-- http://purl.org/dc/terms/bibliographicCitation -->

    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/bibliographicCitation">
    <rdfs:domain rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleRecording"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
    <rdfs:comment xml:lang="en">
        A bibliographic reference for the resource.
    </rdfs:comment>
    <rdfs:isDefinedBy>http://purl.org/dc/terms/bibliographicCitation</rdfs:isDefinedBy>
    <rdfs:label xml:lang="en">Bibliographic Citation</rdfs:label>
    </owl:DatatypeProperty>

    <!-- http://purl.org/dc/terms/created -->
    
    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/created">
    <rdfs:domain rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleRecording"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <rdfs:comment xml:lang="en">
        Date of creation of the resource.
    </rdfs:comment>
    <rdfs:isDefinedBy>http://purl.org/dc/terms/created</rdfs:isDefinedBy>
    <rdfs:label xml:lang="en">Date Created</rdfs:label>
    </owl:DatatypeProperty>

 

    <!-- http://purl.org/dc/terms/description -->
    
    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/description">
    <rdfs:domain rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleRecording"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
    <rdfs:comment xml:lang="en">
        An account of the resource.
    </rdfs:comment>
    <rdfs:isDefinedBy>http://purl.org/dc/terms/description</rdfs:isDefinedBy>
    <rdfs:label xml:lang="en">Description</rdfs:label>
    </owl:DatatypeProperty>
    
    <!-- http://purl.org/dc/terms/identifier -->
    
    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/identifier">
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
    <rdfs:comment xml:lang="en">
        An unambiguous reference to the resource within a given context.
    </rdfs:comment>
    <rdfs:isDefinedBy>http://purl.org/dc/terms/identifier</rdfs:isDefinedBy>
    <rdfs:label xml:lang="en">Identifier</rdfs:label>
    </owl:DatatypeProperty>

    <!-- http://www.w3.org/2004/02/skos/core#prefLabel -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/2004/02/skos/core#prefLabel">
    <rdfs:domain rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleType"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
    <rdfs:comment xml:lang="en">
        The preferred lexical label for a concept. In this profile it is used for the canonical human-readable
        label of a folktale type, for example “ATU 425C Beauty and the Beast”.
    </rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core#prefLabel"/>
    <rdfs:label xml:lang="en">preferred label</rdfs:label>
    </owl:DatatypeProperty>


    <!-- http://www.w3.org/2004/02/skos/core#notation -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/2004/02/skos/core#notation">
    <rdfs:domain rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleType"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
    <rdfs:comment xml:lang="en">
        A lexical code used to identify a concept within the scope of a concept scheme.
        In this profile it is used for folktale type codes such as “425C”.
    </rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core#notation"/>
    <rdfs:label xml:lang="en">notation</rdfs:label>
    </owl:DatatypeProperty>


    <!-- http://www.w3.org/2004/02/skos/core#definition -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition">
    <rdfs:domain rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleType"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
    <rdfs:comment xml:lang="en">
        A statement or formal explanation of the meaning of a concept.
        In this profile it is used for the prose definition of a folktale type.
    </rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
    <rdfs:label xml:lang="en">definition</rdfs:label>
    </owl:DatatypeProperty>




    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

     <!-- https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleContent -->


    <owl:Class rdf:about="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleContent">
    <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E28_Conceptual_Object"/>

    <rdfs:comment xml:lang="en">
        This class represents the abstract narrative content of a folktale, independent of 
        any particular archival fixation. In this profile, TaleContent is used as the content 
        layer to which folktale type assignments are attached. A TaleContent may be linked to 
        one or more controlled tale-type concepts via dcterms:subject and may be connected to 
        one or more TaleRecording entities that document concrete archival realisations of 
        that content.
    </rdfs:comment>

    <rdfs:isDefinedBy rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleContent"/>
    <rdfs:label xml:lang="en">TaleContent</rdfs:label>
    <rdfs:seeAlso rdf:resource="https://github.com/eugeniavd/magic_tagger/blob/main/rdf/ontology/ontology_overview.md"/>
    </owl:Class>



    <!-- https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleRecording -->

    <owl:Class rdf:about="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleRecording">
    <!-- Light alignment -->
    <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E33_Linguistic_Object"/>

    <rdfs:subClassOf>
        <owl:Restriction>
            <owl:onProperty rdf:resource="http://purl.org/dc/terms/identifier"/>
            <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
        <owl:Restriction>
            <owl:onProperty rdf:resource="http://purl.org/dc/terms/isPartOf"/>
            <owl:someValuesFrom rdf:resource="http://purl.org/dc/terms/BibliographicResource"/>
        </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
        <owl:Restriction>
            <owl:onProperty rdf:resource="http://purl.org/dc/terms/spatial"/>
            <owl:someValuesFrom rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E53_Place"/>
        </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="en">
        This class represents an archival recording of a folktale in the corpus. In the profile, a TaleRecording
        is modelled as a CIDOC CRM linguistic object and a PROV entity. It carries the archival identifier,
        bibliographic citation, date of recording, textual description, access status, and spatial information.
        A TaleRecording is linked to its parent Volume and Collection via dcterms:isPartOf, may point to its
        source volume via dcterms:source and may record attributed agents and their qualified attributions.
    </rdfs:comment>

    <rdfs:isDefinedBy rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleRecording"/>
    <rdfs:label xml:lang="en">Tale Recording</rdfs:label>
    <rdfs:seeAlso rdf:resource="https://github.com/eugeniavd/magic_tagger/blob/main/rdf/ontology/ontology_overview.md"/>
    </owl:Class>


    <!-- http://purl.org/dc/terms/BibliographicResource -->

    <owl:Class rdf:about="http://purl.org/dc/terms/BibliographicResource">

    <rdfs:subClassOf>
        <owl:Restriction>
            <owl:onProperty rdf:resource="http://purl.org/dc/terms/identifier"/>
            <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
        <owl:Restriction>
            <owl:onProperty rdf:resource="http://purl.org/dc/terms/isPartOf"/>
            <owl:someValuesFrom rdf:resource="http://purl.org/dc/dcmitype/Collection"/>
        </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
        <owl:Restriction>
            <owl:onProperty rdf:resource="http://xmlns.com/foaf/0.1/page"/>
            <owl:someValuesFrom rdf:resource="http://xmlns.com/foaf/0.1/Document"/>
        </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
        <owl:Restriction>
            <owl:onProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#seeAlso"/>
            <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Resource"/>
        </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="en">
        This class represents an archival volume-level record in the corpus. In the current RDF export, volume resources
        are typed as dcterms:BibliographicResource. Volumes are linked to their parent archival
        collection via dcterms:isPartOf, can carry multiple identifiers (including external catalogue identifiers),
        and can record responsibility information via prov:qualifiedAttribution and/or prov:wasAttributedTo.
        A link to the corresponding public catalogue entry may be given via foaf:page.
    </rdfs:comment>

    <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/BibliographicResource"/>
    <rdfs:label xml:lang="en">Bibliographic Resource</rdfs:label>
</owl:Class>


<!-- http://purl.org/dc/dcmitype/Collection -->

<owl:Class rdf:about="http://purl.org/dc/dcmitype/Collection">
    <!-- Profile constraints used by MagicTagger for collection resources -->

    <rdfs:subClassOf>
        <owl:Restriction>
            <owl:onProperty rdf:resource="http://purl.org/dc/terms/identifier"/>
            <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
        <owl:Restriction>
            <owl:onProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#label"/>
            <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
        <owl:Restriction>
            <owl:onProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#seeAlso"/>
            <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Resource"/>
        </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="en">
        Application-profile constraints for collection-level resources. The class represents collections of documents in Russian language
         of the Estonian Folklore Archive. In the RDF export, collection
        resources are typed as dcmitype:Collection. They carry a human-readable label, a local identifier, and may link
        to an external catalogue KIVIKE via rdfs:seeAlso.
    </rdfs:comment>

    <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/dcmitype/Collection"/>
    <rdfs:label xml:lang="en">Collection</rdfs:label>
    </owl:Class>
    

    <!-- http://www.cidoc-crm.org/cidoc-crm/E28_Conceptual_Object -->

    <owl:Class rdf:about="http://www.cidoc-crm.org/cidoc-crm/E28_Conceptual_Object">
    <rdfs:comment xml:lang="en">
        This class comprises non-material products of human cognition and other human-produced data that become
        objects of discourse about their identity, circumstances of creation, or historical implications. Instances
        can exist simultaneously on multiple carriers (e.g., paper, signals, memory) and persist as long as at least
        one carrier or memory remains. In the project it represents the content of a folktale.
    </rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E28_Conceptual_Object"/>
    <rdfs:label xml:lang="en">Conceptual Object</rdfs:label>
    </owl:Class>


    <!-- http://www.w3.org/ns/prov#Agent -->
    <owl:Class rdf:about="http://www.w3.org/ns/prov#Agent">

    <rdfs:comment xml:lang="en">
        Something that bears responsibility for an activity taking place, such as a person or organization.
    </rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#Agent"/>
    <rdfs:label xml:lang="en">Agent</rdfs:label>
    </owl:Class>

    <!-- http://xmlns.com/foaf/0.1/Person -->
    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Person">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Agent"/>
    <rdfs:comment xml:lang="en">
        A person. In this profile, persons are treated as agents associated with folktale recordings.
    </rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
    <rdfs:label xml:lang="en">Person</rdfs:label>
    </owl:Class>


    <owl:Class rdf:about="http://www.w3.org/ns/prov#Attribution">
    <rdfs:comment xml:lang="en">
        A qualified ascription of an entity to an agent.
        In this profile it is used to qualify the relation between a TaleRecording and an agent,
        including the role of that agent in the recorded tale entry.
    </rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#Attribution"/>
    <rdfs:label xml:lang="en">Attribution</rdfs:label>
    </owl:Class> 
    

    <!-- http://www.w3.org/ns/prov#Role -->

   <owl:Class rdf:about="http://www.w3.org/ns/prov#Role">
    <rdfs:comment xml:lang="en">
        A role that an agent may have with respect to an entity, activity, or influence.
        In this profile, role values are used in qualified attributions for tale recordings.
    </rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#Role"/>
    <rdfs:label xml:lang="en">Role</rdfs:label>
    </owl:Class>

     <!-- http://www.cidoc-crm.org/cidoc-crm/E53_Place -->

    <owl:Class rdf:about="http://www.cidoc-crm.org/cidoc-crm/E53_Place">
    <rdfs:comment xml:lang="en">
        This class comprises extents in natural space, in particular on the surface of the earth, understood as
        spatial regions independent of temporal phenomena and matter. Instances of E53 Place may be used to
        describe the physical location of things or phenomena or other areas of interest. 
    </rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E53_Place"/>
    <rdfs:label xml:lang="en">Place</rdfs:label>
    </owl:Class>

    <!-- https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleType -->

    <owl:Class rdf:about="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleType">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:comment xml:lang="en">
        This class represents a folktale type concept used in the project classification profile.
        It is aligned with skos:Concept and is used for ATU types and other controlled tale-type
        categories assigned to TaleContent resources.
    </rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#TaleType"/>
    <rdfs:label xml:lang="en">Tale Type</rdfs:label>
    </owl:Class>



    <!-- http://www.w3.org/2004/02/skos/core#ConceptScheme -->

    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme">
    <rdfs:subClassOf>
        <owl:Restriction>
            <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#prefLabel"/>
            <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">
        A set of concepts, optionally including statements about semantic relationships between those concepts.
        In this profile, the class is used for controlled tale-type schemes such as the ATU classification
        and other type systems used to organize folktale concepts.
    </rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    <rdfs:label xml:lang="en">Concept Scheme</rdfs:label>
    </owl:Class>

   


     <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <!-- https://eugeniavd.github.io/magic_tagger/rdf/ontology#rights_open -->

    <owl:NamedIndividual rdf:about="https://eugeniavd.github.io/magic_tagger/rdf/ontology#rights_open">
    <rdf:type rdf:resource="http://purl.org/dc/terms/RightsStatement"/>
    <rdfs:comment xml:lang="en">
        A rights statement indicating that the resource and its metadata are openly accessible.
    </rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#rights_open"/>
    <rdfs:label xml:lang="en">open</rdfs:label>
    </owl:NamedIndividual>

    <!-- https://eugeniavd.github.io/magic_tagger/rdf/ontology#rights_partly_anonymised -->

    <owl:NamedIndividual rdf:about="https://eugeniavd.github.io/magic_tagger/rdf/ontology#rights_partly_anonymised">
    <rdf:type rdf:resource="http://purl.org/dc/terms/RightsStatement"/>
    <rdfs:label xml:lang="en">partly anonymised</rdfs:label>
    <rdfs:comment xml:lang="en">
        A rights statement indicating that the metadata of the resource is partly anonymised.
    </rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#rights_partly_anonymised"/>
    </owl:NamedIndividual>


    <!-- http://id.loc.gov/vocabulary/relators/col -->

    <owl:NamedIndividual rdf:about="http://id.loc.gov/vocabulary/relators/col">
    <rdf:type rdf:resource="http://www.w3.org/ns/prov#Role"/>
    <rdfs:label xml:lang="en">Collector</rdfs:label>
    <rdfs:comment xml:lang="en">
        Role value used for an agent acting as collector of a tale recording.
    </rdfs:comment>
    </owl:NamedIndividual>

   <!-- http://id.loc.gov/vocabulary/relators/nrt -->

    <owl:NamedIndividual rdf:about="http://id.loc.gov/vocabulary/relators/nrt">
    <rdf:type rdf:resource="http://www.w3.org/ns/prov#Role"/>
    <rdfs:label xml:lang="en">Narrator</rdfs:label>
    <rdfs:comment xml:lang="en">
        Role value used for an agent acting as narrator of a tale recording.
    </rdfs:comment>
    </owl:NamedIndividual>

    <!-- https://eugeniavd.github.io/magic_tagger/rdf/ontology#ATU_Scheme -->

    <owl:NamedIndividual rdf:about="https://eugeniavd.github.io/magic_tagger/rdf/ontology#ATU_Scheme">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    <skos:prefLabel xml:lang="en">ATU classification scheme</skos:prefLabel>
    <rdfs:comment xml:lang="en">
        Concept scheme used for folktale type concepts based on the Aarne-Thompson-Uther classification.
    </rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://eugeniavd.github.io/magic_tagger/rdf/ontology#ATU_Scheme"/>
    </owl:NamedIndividual>

