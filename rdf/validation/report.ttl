@prefix rft: <https://eugeniavd.github.io/magic_tagger/rdf/ontology#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

[] a sh:ValidationReport ;
    sh:conforms false ;
    sh:result [ a sh:ValidationResult ;
            sh:focusNode <https://eugeniavd.github.io/magic_tagger/rdf/TaleRecording/tru_vkk_25_120_23> ;
            sh:resultMessage "TaleRecording must have at least one narrator attribution (prov:hadRole locrel:nrt)." ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraint [ a sh:SPARQLConstraint ;
                    sh:message "TaleRecording must have at least one narrator attribution (prov:hadRole locrel:nrt)." ;
                    sh:select """
      SELECT $this WHERE {
        FILTER NOT EXISTS {
          $this prov:qualifiedAttribution ?att .
          ?att rdf:type prov:Attribution ;
               prov:hadRole locrel:nrt ;
               prov:agent ?n .
        }
      }
    """ ] ;
            sh:sourceConstraintComponent sh:SPARQLConstraintComponent ;
            sh:sourceShape rft:TaleRecordingShape ;
            sh:value <https://eugeniavd.github.io/magic_tagger/rdf/TaleRecording/tru_vkk_25_120_23> ] .

